{
  "name": "flowwork",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev":              "concurrently \"yarn dev:frontend\" \"yarn dev:backend\"",
    "dev:frontend":     "yarn workspace @flowwork/frontend dev",
    "dev:backend":      "yarn workspace @flowwork/backend dev",

    "build:frontend":   "yarn workspace @flowwork/frontend build",
    "build:backend":    "yarn workspace @flowwork/backend build",

    "start:backend":    "yarn workspace @flowwork/backend start",

    "typecheck":        "yarn workspace @flowwork/frontend typecheck && yarn workspace @flowwork/backend typecheck",
    "lint":             "yarn workspace @flowwork/frontend lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
