{
  "name": "flowwork",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "nx run-many --target=dev --all --parallel",
    "dev:frontend": "nx run frontend:dev",
    "dev:backend": "nx run backend:dev",

    "build": "nx run-many --target=build --all",
    "build:frontend": "nx run frontend:build",
    "build:backend": "nx run backend:build",

    "start:backend": "nx run backend:start",

    "typecheck": "nx run-many --target=typecheck --all",
    "lint": "nx run-many --target=lint --all"
  },
  "devDependencies": {
    "nx": "^20.0.0"
  }
}
